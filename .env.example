DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_DATABASE=

# AWS — used by the API to call Lambda (highlight MP4 export) and S3. Not the same as RDS login above.
# On a VPS you still set these unless the process uses an instance/task IAM role.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional (STS / assumed role)
# AWS_SESSION_TOKEN=

# mux-m3u8-converter function name (only if HIGHLIGHT_MP4_EXPORT_STRATEGY uses Lambda)
MUX_CONVERTER_LAMBDA_FUNCTION_NAME=

# Highlight share MP4:
# - mux_then_lambda — try Mux static MP4 first, then Lambda (default in code if unset)
# - mux_static — Mux only; use when you do NOT deploy the m3u8-converter Lambda
# - lambda — Lambda only (skips Mux static path)
HIGHLIGHT_MP4_EXPORT_STRATEGY=mux_then_lambda

# When using mux_static / mux_then_lambda: auto POST .../static-renditions for legacy clips (default on). Set false to disable.
# After backfill: npm run audit:highlight-mux-mp4 -- --limit=...
# npm run backfill:highlight-mux-static-mp4 -- --limit=50 [--wait] [--dry-run]
HIGHLIGHT_MUX_AUTO_REQUEST_STATIC_MP4=true

# Mux — API access (create assets, etc.)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
# Mux — signed HLS (Dashboard → Settings → Signing keys; not the same as API tokens)
MUX_SIGNING_KEY_ID=
# Base64 (one line) or PEM with \\n; optional — omit to keep new assets on public playback
MUX_PRIVATE_KEY=
# Public API origin for shareable links — must match the host that serves `GET /shared/media/:token` (no trailing slash).
# Example production: https://api.devionx.com
APP_BASE_URL=

# Firebase Admin (phone auth: verify ID tokens from the mobile app)
# Download a service account JSON from Firebase Console → Project settings → Service accounts.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# PEM private key; in .env use \n between lines (same as the JSON "private_key" field).
FIREBASE_PRIVATE_KEY=

# Optional: Firebase App Check debug token (register this in Firebase Console → App Check → Debug tokens)
FIREBASE_APP_CHECK_DEBUG_TOKEN=

# Fast2SMS DLT (phone OTP — `GET https://www.fast2sms.com/dev/bulkV2`)
FAST2SMS_AUTHORIZATION=
FAST2SMS_SENDER_ID=
# DLT template id from Fast2SMS (the `message=` parameter, e.g. 213983)
FAST2SMS_DLT_MESSAGE_ID=

# Razorpay (see docs/payment-gateway-integration.md) — key secret is server-only; never expose to mobile/frontend
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=