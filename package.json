{
  "name": "field-flicks-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format:fix": "prettier --write \"***/**/*.ts\" \"test/**/*.ts\" \"**/*.json\" \"**/*.md\"",
    "format:check": "prettier --check '**/*.{ts,js,json,md}'",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node --env-file .env.production dist/src/main",
    "lint:check": "eslint . --ext .ts --ignore-path .gitignore",
    "lint:fix": "eslint . --ext .ts --fix --ignore-path .gitignore",
    "test": "jest",
    "test:all": "jest --coverage --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "pre-commit-hook:check": "npm run format:fix",
    "pre-commit-hook:add": "husky init && echo 'npm run lint:check\\nnpm run format:check' > .husky/pre-commit",
    "prepare": "husky",
    "typeorm": "npm run build && npx typeorm -d dist/db/data-source.js",
    "migration:generate": "npm run typeorm -- migration:generate",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "deploy": "serverless deploy",
    "deploy:lambda": "serverless deploy function --function muxM3u8Converter",
    "offline": "serverless offline",
    "remove": "serverless remove",
    "db:turf-sports:dry-run": "node scripts/apply-turf-sports-supported.mjs",
    "db:turf-sports:apply": "node scripts/apply-turf-sports-supported.mjs --apply",
    "db:verify-turfs": "node scripts/verify-all-turf-sports.mjs",
    "db:check-turf-arenas": "node scripts/check-turf-arenas.mjs",
    "db:check-courts": "node scripts/check-courts-vs-spreadsheet.mjs",
    "qr:index": "node scripts/index-qr-codes.mjs",
    "qr:index:no-audit": "node scripts/index-qr-codes.mjs --no-audit",
    "db:fix-cricket:dry-run": "node scripts/fix-cricket-recordings-sport.mjs",
    "db:fix-cricket:apply": "node scripts/fix-cricket-recordings-sport.mjs --apply",
    "db:audit-cricket": "node scripts/audit-cricket-misattributed.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.901.0",
    "@aws-sdk/client-s3": "^3.810.0",
    "@aws-sdk/client-sqs": "^3.989.0",
    "@aws-sdk/lib-storage": "^3.810.0",
    "@aws-sdk/s3-request-presigner": "^3.810.0",
    "@mux/mux-node": "^11.1.0",
    "@nestjs/axios": "^3.1.3",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^4.1.1",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/typeorm": "^10.0.2",
    "@types/multer": "^1.4.12",
    "@types/passport-google-oauth20": "^2.0.16",
    "axios": "^1.12.2",
    "body-parser": "^2.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "firebase-admin": "^13.2.0",
    "helmet": "^7.1.0",
    "jose": "^4.15.9",
    "jwt-decode": "^4.0.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.0",
    "razorpay": "^2.9.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "serverless-deployment-bucket": "^1.6.0",
    "serverless-dotenv-plugin": "^6.0.0",
    "serverless-esbuild": "^1.55.1",
    "serverless-plugin-warmup": "^8.3.0",
    "serverless-prune-plugin": "^2.1.0",
    "tekvo-nest-typeorm-paginate": "^4.0.5",
    "typeorm": "^0.3.20",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/testing": "^10.4.18",
    "@types/aws-lambda": "^8.10.149",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.3.1",
    "@types/pg": "^8.11.10",
    "jsqr": "^1.4.0",
    "pngjs": "^7.0.0",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "serverless": "^3.38.0",
    "serverless-offline": "^13.9.0",
    "serverless-plugin-typescript": "^2.1.5",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.3.4",
    "ts-loader": "^9.4.3",
    "ts-mockito": "^2.6.1",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  }
}
